# Runtime
JARVIS_ENV=development
JARVIS_LOG_LEVEL=INFO

# Storage
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jarvis
VECTOR_STORE_URL=postgresql://postgres:postgres@localhost:5432/jarvis
JARVIS_OBSERVABILITY_DB=.jarvis_runtime/observability.db
JARVIS_EVOLUTION_DB=.jarvis_runtime/evolution.db

# Providers
OPENAI_API_KEY=
LANGSMITH_API_KEY=

# Observability
LANGSMITH_TRACING=false
